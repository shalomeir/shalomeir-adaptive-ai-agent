# Provider settings. Copy this file to .env and edit. .env is loaded on `chat`.
#
# Default: local Ollama (no API key). Make sure the model is pulled:
#   ollama pull qwen2.5-coder:7b
AGENT_PROVIDER=openai-compatible
AGENT_BASE_URL=http://localhost:11434/v1
AGENT_MODEL=qwen2.5-coder:7b
AGENT_MONITORING=off

# --- To use OpenAI instead, comment out the three Ollama lines above and
# --- uncomment the four lines below, then put your key in AGENT_API_KEY.
# AGENT_PROVIDER=openai
# AGENT_BASE_URL=https://api.openai.com/v1
# AGENT_MODEL=gpt-4o-mini
# AGENT_API_KEY=sk-your-key-here
