# Provider settings. Copy this file to .env and edit. .env is loaded by the CLI.
# Shell-exported AGENT_* variables take precedence over values in this file.
#
# Default: local Ollama (no API key). Setup is complete after:
#   cp .env.example .env
#   ollama pull qwen2.5-coder:7b
AGENT_PROVIDER=openai-compatible
AGENT_BASE_URL=http://localhost:11434/v1
AGENT_MODEL=qwen2.5-coder:7b
AGENT_MONITORING=off

# Runtime limits and local paths.
AGENT_MAX_ITERATIONS=20
AGENT_MAX_FIX_RETRIES=3
AGENT_TOOL_TIMEOUT_SEC=20
AGENT_LLM_TIMEOUT_SEC=60
AGENT_MAX_OUTPUT_BYTES=65536
AGENT_COMPACTION_TOKEN_THRESHOLD=12000
AGENT_WORKSPACE_DIR=./workspace
AGENT_SKILLS_DIR=./skills
AGENT_LOG_DIR=./logs
AGENT_NETWORK_DEFAULT=deny

# --- OpenAI API
# To use OpenAI instead, uncomment the four lines below, then put your key in
# AGENT_API_KEY. The later values take precedence in this file.
# AGENT_PROVIDER=openai
# AGENT_BASE_URL=https://api.openai.com/v1
# AGENT_MODEL=gpt-5.4-mini
# AGENT_API_KEY=sk-your-key-here

# --- Claude API via Anthropic Messages API
# To use Claude instead, uncomment the four lines below, then put your key in
# AGENT_API_KEY. Use a Claude model name available to your Anthropic account.
# Opus 4.8 uses the hyphenated Anthropic model ID: claude-opus-4-8.
# AGENT_PROVIDER=anthropic
# AGENT_BASE_URL=https://api.anthropic.com/v1
# AGENT_MODEL=claude-haiku-4-5
# AGENT_API_KEY=sk-ant-your-key-here

# --- Vercel AI Gateway
# To use Vercel AI Gateway instead, uncomment the four lines below, then put
# your AI Gateway key in AGENT_API_KEY.
# AGENT_PROVIDER=vercel-ai-gateway
# AGENT_BASE_URL=https://ai-gateway.vercel.sh/v1
# AGENT_MODEL=anthropic/claude-sonnet-4.6
# AGENT_API_KEY=your-ai-gateway-key-here

# --- OpenRouter
# To use OpenRouter instead, uncomment the four lines below, then put your
# OpenRouter API key in AGENT_API_KEY. Optional OpenRouter attribution headers
# are not required for this CLI.
# AGENT_PROVIDER=openrouter
# AGENT_BASE_URL=https://openrouter.ai/api/v1
# AGENT_MODEL=openrouter/free
# AGENT_API_KEY=sk-or-your-key-here
